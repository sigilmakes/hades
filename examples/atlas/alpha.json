{
  "apiVersion": "hades.dev/v1alpha1",
  "kind": "AgentClass",
  "metadata": { "namespace": "agent-atlas", "name": "resident-pi" },
  "spec": {
    "brainImage": "ghcr.io/hades-dev/hades-brain:dev",
    "allowedTools": ["read", "write", "bash", "os.createSchedule", "os.spawnAgent"],
    "defaultHandsPolicy": "home-sandbox"
  }
}
---
{
  "apiVersion": "hades.dev/v1alpha1",
  "kind": "Agent",
  "metadata": { "namespace": "agent-atlas", "name": "atlas" },
  "spec": {
    "displayName": "Atlas",
    "classRef": "resident-pi",
    "homeRef": "atlas-home",
    "defaultSession": "atlas-default",
    "desiredState": "active",
    "brain": { "mode": "test" }
  }
}
---
{
  "apiVersion": "hades.dev/v1alpha1",
  "kind": "Home",
  "metadata": { "namespace": "agent-atlas", "name": "atlas-home" },
  "spec": {
    "layout": { "create": ["vault", "bin", "cron.d", "projects", "skills", "inbox", "outbox"] },
    "files": [
      {
        "path": "vault/README.md",
        "content": "# Atlas\n\nThis is Atlas's Hades userland. The kernel provides the Agent/Home/Session/Brain/Hands/Listener/Schedule primitives; Atlas owns the content here.\n"
      },
      {
        "path": "cron.d/morning-ritual.md",
        "content": "Good morning. Orient from the session log and vault, check schedules, and say hello. If anything looks broken, explain it plainly.\n"
      },
      {
        "path": "cron.d/recess.md",
        "content": "Take a short recess: pick one small harmless creative or maintenance task in your own home and report what changed.\n"
      }
    ]
  }
}
---
{
  "apiVersion": "hades.dev/v1alpha1",
  "kind": "Listener",
  "metadata": { "namespace": "agent-atlas", "name": "atlas-cli" },
  "spec": { "agentRef": "atlas", "platform": "cli", "routes": "default" }
}
---
{
  "apiVersion": "hades.dev/v1alpha1",
  "kind": "Listener",
  "metadata": { "namespace": "agent-atlas", "name": "atlas-discord" },
  "spec": {
    "agentRef": "atlas",
    "platform": "discord",
    "secretRef": "atlas-discord-token",
    "routes": "default"
  }
}
---
{
  "apiVersion": "hades.dev/v1alpha1",
  "kind": "Schedule",
  "metadata": { "namespace": "agent-atlas", "name": "morning-ritual" },
  "spec": {
    "agentRef": "atlas",
    "type": "cron",
    "schedule": "0 7 * * *",
    "session": "atlas-default",
    "promptRef": { "homePath": "cron.d/morning-ritual.md" },
    "prompt": "Good morning. Orient from the session log and vault, check schedules, and say hello."
  },
  "status": { "phase": "pending" }
}
---
{
  "apiVersion": "hades.dev/v1alpha1",
  "kind": "Schedule",
  "metadata": { "namespace": "agent-atlas", "name": "recess" },
  "spec": {
    "agentRef": "atlas",
    "type": "cron",
    "schedule": "45 10,14,18 * * *",
    "session": "atlas-default",
    "promptRef": { "homePath": "cron.d/recess.md" },
    "prompt": "Take a short recess in your own home and report what changed."
  },
  "status": { "phase": "pending" }
}
---
{
  "apiVersion": "hades.dev/v1alpha1",
  "kind": "CapabilityGrant",
  "metadata": { "namespace": "agent-atlas", "name": "atlas-self-management" },
  "spec": {
    "subject": { "kind": "Agent", "name": "atlas" },
    "capabilities": ["createOwnSchedule", "spawnAgent", "createHome", "emitArtifact"],
    "constraints": { "namespace": "own", "maxChildDepth": 2 }
  }
}
