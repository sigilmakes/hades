{
  "name": "@sigilmakes/hades",
  "version": "0.1.0",
  "description": "Kubernetes-native agent operating system prototype",
  "type": "module",
  "bin": {
    "hades": "dist/cli.js",
    "hades-brain-pod": "dist/brain-pod/cli.js",
    "hades-hands-pod": "dist/hands-pod/cli.js"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "npm run clean --silent && tsc",
    "test": "npm run build && node --test",
    "demo": "npm run build && node dist/cli.js demo",
    "serve": "npm run build && node dist/cli.js serve",
    "hades": "npm run build --silent && node dist/cli.js",
    "brain-pod": "npm run build --silent && node dist/brain-pod/cli.js",
    "hands-pod": "npm run build --silent && node dist/hands-pod/cli.js",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.10",
    "@earendil-works/pi-coding-agent": "^0.79.10",
    "@kubernetes/client-node": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "croner": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist/",
    "infra/",
    "examples/",
    "docs/",
    "README.md"
  ]
}
