# Brain pod — embeds the pi SDK model/harness loop.
# One pod per active agent. Exposes POST /run (+ SSE) over HTTP.
FROM node:24-slim

RUN apt-get update -qq && apt-get install -y --no-install-recommends python3 make g++ && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json tsconfig.json ./
RUN npm ci

COPY src ./src
COPY scripts ./scripts
RUN npm run build

ENV NODE_ENV=development
CMD ["node", "dist/brain-pod/cli.js"]
