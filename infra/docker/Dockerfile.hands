# Hands pod — a thin execution sandbox.
# Runs `sleep infinity`; the brain execs read/write/exec into it via the k8s
# exec API. The agent Home is mounted at /home/agent. No model credentials
# are ever mounted here.
FROM node:24-slim

RUN mkdir -p /home/agent && chown -R node:node /home/agent

USER node
WORKDIR /home/agent

CMD ["sleep", "infinity"]
